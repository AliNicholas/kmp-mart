{
  "expo": {
    "name": "KMP Mart",
    "slug": "kmp-mart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./kmp-mart-logo.png",
    "scheme": "kmpmart",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./kmp-mart-logo.png",
      "bundleIdentifier": "com.thenotoriousgustav.kmpmart",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.kmpmart"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./kmp-mart-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./kmp-mart-logo.png",
          "imageWidth": 96
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8e9c9b33-d8e6-4267-a52e-586159ddcace"
      }
    },
    "owner": "nicholasali"
  }
}
